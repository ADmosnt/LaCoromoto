# ─────────────────────────────────────────────
# Variables para desarrollo local (docker compose)
# ─────────────────────────────────────────────

# Contraseña de PostgreSQL local (solo se usa con docker-compose, no en Railway)
DB_PASSWORD=dev_password_local

# Clave secreta de Flask — puede ser cualquier string largo y aleatorio
# En Railway, configúrala en el dashboard (Settings → Variables)
SECRET_KEY=cambia-esto-por-un-string-largo-y-aleatorio-en-produccion
